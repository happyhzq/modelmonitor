# Server
PORT=8787
MODEL_MONITOR_DATA_DIR=./data/sources
MODEL_MONITOR_SAMPLE_FALLBACK=true
MODEL_MONITOR_PUBLIC_WEB=true
MODEL_MONITOR_PUBLIC_WEB_TTL_SECONDS=900

# Direct usage APIs
OPENAI_ADMIN_KEY=
ANTHROPIC_ADMIN_KEY=
OPENROUTER_API_KEY=
OPENROUTER_GENERATION_IDS=

# Azure Monitor REST connector
AZURE_MONITOR_BEARER_TOKEN=
AZURE_OPENAI_RESOURCE_IDS=

# Generic normalized endpoints, comma-separated URLs returning ModelUsageRecord[] or {modelRecords, agentRecords}
MODEL_MONITOR_HTTP_JSON_SOURCES=

# MySQL persistence. Keep real values in .env only; .env is ignored by git.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=modelmonitor
MODEL_MONITOR_MYSQL_ENABLED=true
MODEL_MONITOR_MYSQL_READ=true
